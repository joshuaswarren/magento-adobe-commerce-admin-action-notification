<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="creatuity_admin_notification_rule" engine="innodb" resource="default">
        <column name="rule_id" xsi:type="int" unsigned="true" identity="true" nullable="false"/>
        <column name="rule_name" xsi:type="varchar" nullable="false"/>
        <column name="notification_frequency" xsi:type="int" unsigned="true" nullable="false" default="1440" comment="Frequency in minutes"/>
        <column name="last_notification" xsi:type="timestamp" nullable="true" default="NULL"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="rule_id"/>
        </constraint>
    </table>

    <table name="creatuity_admin_notification_rule_entity" engine="innodb" resource="default">
        <column name="rule_entity_id" xsi:type="int" unsigned="true" nullable="false" identity="true"/>
        <column name="rule_id" xsi:type="int" unsigned="true" nullable="false"/>
        <column name="entity" xsi:type="varchar" nullable="false"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="rule_entity_id"/>
        </constraint>

        <constraint xsi:type="foreign"
                    referenceId="CREATUITY_ADMIN_NOTIFICATION_RULE_ENTITY_RULE_ID_CREATUITY_ADMIN_NOTIFICATION_RULE_RULE_ID"
                    table="creatuity_admin_notification_rule_entity"
                    column="rule_id"
                    referenceTable="creatuity_admin_notification_rule"
                    referenceColumn="rule_id"
                    onDelete="CASCADE"
        />

        <constraint xsi:type="unique" referenceId="CREATUITY_ADMIN_NOTIFICATION_RULE_ENTITY_RULE_ID_ENTITY_UNIQUE">
            <column name="rule_id"/>
            <column name="entity"/>
        </constraint>
    </table>

    <table name="creatuity_admin_notification_channel" engine="innodb" resource="default">
        <column name="channel_id" xsi:type="int" unsigned="true" nullable="false" identity="true"/>
        <column name="unique_name" xsi:type="varchar" nullable="false" />
        <column name="channel_type" xsi:type="varchar" length="10" nullable="false" />
        <column name="channel_value" xsi:type="varchar" nullable="false" />

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="channel_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="CREATUITY_ADMIN_NOTIFICATION_CHANNEL_UNIQUE_NAME_UNIQUE">
            <column name="unique_name"/>
        </constraint>
    </table>

    <table name="creatuity_admin_notification_rule_channel" engine="innodb" resource="default">
        <column name="rule_channel_id" xsi:type="int" unsigned="true" nullable="false" identity="true"/>
        <column name="rule_id" xsi:type="int" unsigned="true" nullable="false"/>
        <column name="channel_id" xsi:type="int" unsigned="true" nullable="false"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="rule_channel_id"/>
        </constraint>

        <constraint xsi:type="unique" referenceId="CREATUITY_ADMIN_NOTIFICATION_RULE_CHANNEL_RULE_ID_CHANNEL_ID_UNIQUE">
            <column name="rule_id"/>
            <column name="channel_id"/>
        </constraint>

        <constraint xsi:type="foreign"
                    referenceId="CREATUITY_ADMIN_NOTIFICATION_RULR_CHANNEL_RULE_ID_CREATUITY_ADMIN_NOTIFICATION_RULE_RULE_ID"
                    table="creatuity_admin_notification_rule_channel"
                    column="rule_id"
                    referenceTable="creatuity_admin_notification_rule"
                    referenceColumn="rule_id"
                    onDelete="CASCADE"
        />

        <constraint xsi:type="foreign"
                    referenceId="CREATUITY_ADMIN_NOTIFICATION_RULR_CHANNEL_CHANNEL_ID_CREATUITY_ADMIN_NOTIFICATION_CHANNEL_CHANNEL_ID"
                    table="creatuity_admin_notification_rule_channel"
                    column="channel_id"
                    referenceTable="creatuity_admin_notification_channel"
                    referenceColumn="channel_id"
                    onDelete="CASCADE"
        />
    </table>
</schema>
