<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="creatuity" translate="label" sortOrder="100">
            <label>Creatuity</label>
        </tab>
        <section id="creatuity_admin_action_notification" translate="label" sortOrder="20" showInDefault="1">
            <class>separator-top</class>
            <label>Admin Action Notification</label>
            <tab>creatuity</tab>
            <resource>Creatuity_AdminActionNotification::config</resource>
            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1">
                <label>General</label>
                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
            <group id="slack_config" translate="label" type="text" sortOrder="20" showInDefault="1">
                <label>Slack Config</label>
                <field id="api_key" translate="label" type="obscure" sortOrder="10" showInDefault="1">
                    <label>API Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
            </group>
            <group id="self_notification" translate="label comment" type="text" sortOrder="20" showInDefault="1">
                <label>Self Notification Channel</label>
                <comment>Configuration of the notification channel for changes in notification configuration</comment>
                <field id="channel" type="select" sortOrder="10" translate="label" showInDefault="1">
                    <label>Channel</label>
                    <source_model>Creatuity\AdminActionNotification\OptionSource\ChannelTypeOptionSource</source_model>
                </field>
                <field id="chennel_value" translate="label comment" type="text" showInDefault="1">
                    <label>Value</label>
                    <comment>Adres E-mail or Slack Channel ID</comment>
                </field>
            </group>
        </section>
    </system>
</config>