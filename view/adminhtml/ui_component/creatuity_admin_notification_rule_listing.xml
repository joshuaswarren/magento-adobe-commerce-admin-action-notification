<?xml version="1.0" encoding="UTF-8"?>

<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">creatuity_admin_notification_rule_listing.creatuity_admin_notification_rule_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>columns</spinner>
        <deps>
            <dep>creatuity_admin_notification_rule_listing.creatuity_admin_notification_rule_listing_data_source</dep>
        </deps>
        <buttons>
            <button name="add">
                <url path="*/*/form"/>
                <class>primary</class>
                <label translate="true">New Notification Rule</label>
            </button>
        </buttons>
    </settings>
    <dataSource name="creatuity_admin_notification_rule_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <updateUrl path="mui/index/render"/>
            <storageConfig>
                <param name="indexField" xsi:type="string">rule_id</param>
            </storageConfig>
        </settings>
        <aclResource>Creatuity_AdminActionNotification::admin_action_notification_rules</aclResource>
        <dataProvider class="Creatuity\AdminActionNotification\Ui\Listing\RuleListingDataProvider"
                      name="creatuity_admin_notification_rule_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>rule_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <filters name="listing_filters" />
    </listingToolbar>
    <columns name="columns" class="Creatuity\AdminActionNotification\Ui\Listing\Component\RuleColumns">
        <selectionsColumn name="ids" sortOrder="10">
            <settings>
                <indexField>rule_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="rule_id" sortOrder="20">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>
        <column name="rule_name" sortOrder="25">
            <settings>
                <filter>text</filter>
                <label translate="true">Name</label>
            </settings>
        </column>
        <column name="notification_frequency" sortOrder="28">
            <settings>
                <label translate="true">Notification Frequency (min.)</label>
            </settings>
        </column>
        <column name="channels" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">Channels</label>
            </settings>
        </column>
        <column name="entities" sortOrder="40">
            <settings>
                <filter>text</filter>
                <label translate="true">Tracked Entities</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="Creatuity\AdminActionNotification\Ui\Listing\Component\RuleColumnActions">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="indexField" xsi:type="string">rule_id</item>
                    <item name="sortOrder" xsi:type="number">120</item>
                </item>
            </argument>
        </actionsColumn>
    </columns>
</listing>
