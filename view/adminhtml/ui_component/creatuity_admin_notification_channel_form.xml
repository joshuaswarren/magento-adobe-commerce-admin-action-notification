<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">creatuity_admin_notification_channel_form.creatuity_admin_notification_channel_form_data_source</item>
            <item name="namespace" xsi:type="string">creatuity_admin_notification_channel_form</item>
        </item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <deps>
            <dep>creatuity_admin_notification_channel_form.creatuity_admin_notification_channel_form_data_source</dep>
        </deps>
        <buttons>
            <button name="back">
                <url path="*/*"/>
                <class>secondary</class>
                <label translate="true">Back</label>
            </button>
            <button name="save">
                <label translate="true">Save</label>
                <class>save primary</class>
            </button>
        </buttons>
        <namespace>creatuity_admin_notification_channel_form</namespace>
        <dataScope>data</dataScope>
    </settings>
    <dataSource name="creatuity_admin_notification_channel_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="*/*/save"/>
        </settings>
        <aclResource>Creatuity_AdminActionNotification::admin_action_notification_channels</aclResource>
        <dataProvider class="Creatuity\AdminActionNotification\Ui\Form\ChannelFormDataProvider"
                      name="creatuity_admin_notification_channel_form_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>channel_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general">
        <settings>
            <label />
        </settings>
        <field name="channel_id" formElement="hidden">
            <settings>
                <label />
            </settings>
        </field>
        <field name="unique_name" formElement="input" sortOrder="10">
            <settings>
                <label translate="true">Unique Name</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="channel_type" formElement="select" sortOrder="20">
            <settings>
                <label translate="true">Channel Type</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Creatuity\AdminActionNotification\OptionSource\ChannelTypeOptionSource"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="channel_value" formElement="input" sortOrder="30">
            <settings>
                <label translate="true">Value</label>
                <notice translate="true">E-mail or Slack Channel ID</notice>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
    </fieldset>
</form>
